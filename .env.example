# ============================================================
# Database — Railway Postgres
# В Railway Postgres add-on это заполняется автоматически.
# Для локальной разработки: postgres://user:pass@localhost:5432/usn
# ============================================================
DATABASE_URL=postgresql+asyncpg://usn:usn@localhost:5432/usn

# ============================================================
# Server
# ============================================================
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=console  # console|json (в prod ставь json)

# ============================================================
# CORS — явный список, НЕ "*"
# ============================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================
# Jobs
# ============================================================
JOB_TTL_HOURS=24          # через сколько часов удалять завершённые jobs
MAX_STATEMENT_SIZE_MB=10  # лимит на 1С-выписку
MAX_OFD_SIZE_MB=5         # лимит на ОФД-файл

# ============================================================
# DaData (для штампов ЭДО — данные ИФНС)
# Получить: https://dadata.ru/profile/#info
# ============================================================
DADATA_API_KEY=
DADATA_SECRET_KEY=

# ============================================================
# Feature flags
# ============================================================
ENABLE_OFD_PARSER=true
ENABLE_STAMPS=true
