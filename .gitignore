# User reference PDFs (содержат реальные ПД)
/templates/_user_reference/*.pdf

# Но не исключаем ассеты шаблонов
!/templates/**

# Артефакты автоматической разметки координат — генерируются
# скриптом extract_fields_from_reference.py, не должны быть в git.
# Результат ручной доработки — в fields.json
templates/*/fields_auto.json
templates/*/_classification.json
templates/*/source_page.pdf

# blank.pdf генерируется скриптом make_blank_from_reference.py из source_page.pdf.
# Это ЧИСТЫЙ бланк без персональных данных — безопасно коммитить в git.
# Хранится в репо как артефакт для воспроизводимого рендера квитанций.
# (Не путать с source_page.pdf который СОДЕРЖИТ ПД и находится выше в ignore.)
